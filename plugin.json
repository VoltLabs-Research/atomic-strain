{
  "workflow": {
    "nodes": [
      {
        "id": "plugin-metadata",
        "type": "modifier",
        "position": {
          "x": 240,
          "y": 160
        },
        "data": {
          "modifier": {
            "name": "Atomic Strain",
            "key": "atomic-strain",
            "icon": "HiCube",
            "author": "Rodolfo Herrera",
            "license": "MIT",
            "version": "2.0.0",
            "homepage": "https://github.com/rodyherrera/Volterra",
            "description": "Calcula el tensor de deformacion atomica (deformation gradient, strain tensors, D2min) usando una configuracion de referencia."
          }
        }
      },
      {
        "id": "plugin-arguments",
        "type": "arguments",
        "position": {
          "x": 528,
          "y": 208
        },
        "data": {
          "arguments": {
            "arguments": [
              {
                "argument": "reference",
                "type": "frame",
                "label": "Reference Frame"
              },
              {
                "argument": "cutoff",
                "type": "number",
                "label": "Cutoff",
                "default": 3,
                "min": 0,
                "step": 0.1
              },
              {
                "argument": "eliminate_cell_deformation",
                "type": "boolean",
                "label": "Eliminate Cell Deformation",
                "default": false
              },
              {
                "argument": "assume_unwrapped",
                "type": "boolean",
                "label": "Assume Unwrapped",
                "default": false
              },
              {
                "argument": "calc_deformation_gradient",
                "type": "boolean",
                "label": "Calc Deformation Gradient",
                "default": true
              },
              {
                "argument": "calc_strain_tensors",
                "type": "boolean",
                "label": "Calc Strain Tensors",
                "default": true
              },
              {
                "argument": "calc_d2min",
                "type": "boolean",
                "label": "Calc D2min",
                "default": true
              }
            ]
          }
        }
      },
      {
        "id": "trajectory-context",
        "type": "context",
        "position": {
          "x": 816,
          "y": 160
        },
        "data": {
          "context": {
            "source": "trajectory_dumps"
          }
        }
      },
      {
        "id": "foreach-trajectory-dumps",
        "type": "forEach",
        "position": {
          "x": 1088,
          "y": 208
        },
        "data": {
          "forEach": {
            "iterableSource": "{{ trajectory-context.trajectory_dumps }}"
          }
        }
      },
      {
        "id": "analysis-entrypoint",
        "type": "entrypoint",
        "position": {
          "x": 1392,
          "y": 208
        },
        "data": {
          "entrypoint": {
            "type": "executable",
            "binary": "atomic-strain",
            "binaryObjectPath": "__UPLOAD_BINARY_OBJECT_PATH__",
            "binaryFileName": "atomic-strain",
            "arguments": "{{ foreach-trajectory-dumps.currentValue.path }} {{ foreach-trajectory-dumps.outputPath }} {{ plugin-arguments.as_str }}",
            "timeout": -1
          }
        }
      },
      {
        "id": "primary-exposure",
        "type": "exposure",
        "position": {
          "x": 1712,
          "y": 208
        },
        "data": {
          "exposure": {
            "name": "Atomic Strain",
            "icon": "HiCube",
            "results": "atomic_strain.parquet",
            "iterable": ""
          }
        }
      },
      {
        "id": "atomic-strain-model-exposure",
        "type": "exposure",
        "position": {
          "x": 1712,
          "y": 336
        },
        "data": {
          "exposure": {
            "name": "Atomic Strain Model",
            "icon": "HiCube",
            "results": "atoms.parquet",
            "iterable": ""
          }
        }
      },
      {
        "id": "atomic-strain-model-export",
        "type": "export",
        "position": {
          "x": 2032,
          "y": 336
        },
        "data": {
          "export": {
            "exporter": "AtomisticExporter",
            "type": "glb"
          }
        }
      }
    ],
    "edges": [
      {
        "id": "edge-metadata-arguments",
        "source": "plugin-metadata",
        "sourceHandle": "output",
        "target": "plugin-arguments",
        "targetHandle": "input"
      },
      {
        "id": "edge-arguments-context",
        "source": "plugin-arguments",
        "sourceHandle": "output",
        "target": "trajectory-context",
        "targetHandle": "input"
      },
      {
        "id": "edge-context-foreach",
        "source": "trajectory-context",
        "sourceHandle": "output",
        "target": "foreach-trajectory-dumps",
        "targetHandle": "input"
      },
      {
        "id": "edge-foreach-entrypoint",
        "source": "foreach-trajectory-dumps",
        "sourceHandle": "output",
        "target": "analysis-entrypoint",
        "targetHandle": "input"
      },
      {
        "id": "edge-entrypoint-exposure",
        "source": "analysis-entrypoint",
        "sourceHandle": "output",
        "target": "primary-exposure",
        "targetHandle": "input"
      },
      {
        "id": "edge-entrypoint-atomic-strain-model-exposure",
        "source": "analysis-entrypoint",
        "sourceHandle": "output",
        "target": "atomic-strain-model-exposure",
        "targetHandle": "input"
      },
      {
        "id": "edge-atomic-strain-model-exposure-atomic-strain-model-export",
        "source": "atomic-strain-model-exposure",
        "sourceHandle": "output",
        "target": "atomic-strain-model-export",
        "targetHandle": "input"
      }
    ]
  }
}
